# MCP (Master Control Program) Integration Configuration
# ========================================================

# Required: MCP Base URL - The endpoint URL for the MCP system
# Example: https://mcp.example.com or http://localhost:9000
MCP_BASE_URL=

# Required: MCP API Key - Authentication key for MCP API
# Obtain this from your MCP administrator or DevOps team
MCP_API_KEY=

# Optional: Request timeout in seconds (default: 30)
MCP_TIMEOUT=30

# Optional: Maximum number of retry attempts for failed requests (default: 3)
MCP_MAX_RETRIES=3

# Optional: Enable detailed logging for MCP operations (default: false)
# Set to 'true' for debugging and audit trails
MCP_ENABLE_LOGGING=true
